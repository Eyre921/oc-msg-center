# oc-msg-center — copy to .env and edit, then run `docker compose up -d`.

# Web URL the center advertises (used for QR links and attachment URLs).
MSGCENTER_BASE_URL=http://localhost:2586

# Web login. If unset, a random admin password is generated on first boot and
# printed to docker logs.
MSGCENTER_ADMIN_USERNAME=admin
# MSGCENTER_ADMIN_PASSWORD=

# Headless admin token (curl -H "Authorization: Bearer $MSGCENTER_ADMIN_TOKEN").
# MSGCENTER_ADMIN_TOKEN=

# Welcome message sent to a user after they finish binding.
MSGCENTER_WELCOME_MESSAGE=✅ 你已成功绑定运维通知中心，稍后管理员会把你加入相应分组。

# ---- QQ bridge ---------------------------------------------------------------
# These come from QQ 开放平台 (https://q.qq.com/) — the same AppID/Secret that
# openclaw-qqbot uses. There is no way around it: the QQ official-bot API
# requires this credential pair. Fill them in and uncomment qq-bridge in the
# compose file.
QQBOT_APPID=
QQBOT_SECRET=
QQ_SEND_TOKEN=change-me-please
QQ_INBOUND_TOKEN=change-me-please

# ---- WeChat bridge -----------------------------------------------------------
# openclaw-weixin uses QR-code login — no key required. Uncomment the
# weixin-bridge service, run `docker compose up weixin-bridge` once to scan the
# QR shown in the container logs, then bring the stack up normally.
WEIXIN_SEND_TOKEN=change-me-please
WEIXIN_INBOUND_TOKEN=change-me-please
