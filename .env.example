# oc-msg-center — copy to .env, edit, then `docker compose up -d`.

# Public URL the center advertises (used for QR links and attachment URLs).
MSGCENTER_BASE_URL=http://localhost:2586

# Web login. If unset, a random admin password is generated on first boot and
# printed to docker logs.
MSGCENTER_ADMIN_USERNAME=admin
# MSGCENTER_ADMIN_PASSWORD=

# Headless admin bearer (curl -H "Authorization: Bearer $MSGCENTER_ADMIN_TOKEN").
# MSGCENTER_ADMIN_TOKEN=

# Welcome message sent to a user after they finish binding.
MSGCENTER_WELCOME_MESSAGE=✅ 你已成功绑定运维通知中心，稍后管理员会把你加入相应分组。

# Shared bearer token between msg-center and every bridge sidecar (msg-center
# uses it to POST send/provision, bridges use it to POST inbound back).
BRIDGE_SHARED_TOKEN=please-change-me

# Personal bot credentials (QQ AppID/Secret, WeChat sessions) are NEVER set
# here. Each colleague's bot is added one at a time via the web admin
# (Users → "为该用户添加机器人").
