{
  "name": "oc-msg-center",
  "version": "0.1.0",
  "description": "OpenClaw Message Center — a self-hosted, ntfy-inspired notification hub that pushes and receives messages through QQ / WeChat (via OpenClaw channel plugins), webhooks and the web.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "oc-msg-center": "src/index.ts"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/multipart": "^9.0.1",
    "@fastify/static": "^8.0.3",
    "@fastify/websocket": "^11.0.1",
    "better-sqlite3": "^11.8.1",
    "fastify": "^5.2.0",
    "pino": "^9.5.0",
    "qrcode": "^1.5.4",
    "tsx": "^4.19.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "@types/qrcode": "^1.5.5",
    "pino-pretty": "^13.0.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
